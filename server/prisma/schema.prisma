generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  password  String?  // Made optional because Google Auth users won't have a password
  name      String
  role      String   // "TEACHER" or "STUDENT"
  googleId  String?  @unique
  avatar    String?  // Optional avatar URL from Google Payload
  points    Int      @default(0) // <--- Gamification Points
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// In MVP, a "Session" ties to a teacher who created it
model Session {
  id        String   @id @default(uuid())
  pin       String   @unique
  teacherId String   
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Invite codes for teachers to register securely
model TeacherCode {
  id        String   @id @default(uuid())
  code      String   @unique
  isUsed    Boolean  @default(false)
  usedBy    String?  // Store the user ID of the teacher who used it
  createdAt DateTime @default(now())
}

// Blog Ecosystem
model Post {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  excerpt   String?
  coverImage String? // <--- Added for UI aesthetics
  authorId  String   
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  comments  Comment[]
}

// Comments for Blog Posts
model Comment {
  id        String   @id @default(uuid())
  content   String
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorName String  // Display name of who commented
  authorId   String? // Nullable if guest, or student ID
  createdAt DateTime @default(now())
}

// Comments for Open Library Contents
model LibraryComment {
  id        String   @id @default(uuid())
  content   String
  authorName String
  authorId  String?
  itemId    String
  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------------
// ACADEMY / LIBRARY ARCHITECTURE
// ----------------------------------------------------------------------

model LibraryItem {
  id          String   @id @default(uuid())
  title       String
  videoId     String   // YouTube Video ID
  subject     String   // e.g. "Matematik"
  author      String   // Teacher Name
  authorId    String   // Teacher ID
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  questions   LibraryVideoQuestion[]
}

model LibraryVideoQuestion {
  id            String      @id @default(uuid())
  libraryItemId String
  libraryItem   LibraryItem @relation(fields: [libraryItemId], references: [id], onDelete: Cascade)
  
  // The exact second in the video when this question should pop up
  timestampSec  Int         
  
  // Question text
  prompt        String      
  
  // JSON array of strings e.g. ["Ankara", "İstanbul", "İzmir"]
  options       String      
  
  // Index of the correct option
  correctIndex  Int         
  
  createdAt     DateTime    @default(now())
}

// Persistent Classrooms for Teachers (Google Classroom style)
model Classroom {
  id          String   @id @default(uuid())
  name        String   // e.g. 11-A Tarih
  code        String   @unique // The persistent 6-digit pin or string code
  teacherId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  students    ClassStudent[]
}

// Enrollment relation
model ClassStudent {
  id          String   @id @default(uuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId   String
  studentName String
  enrolledAt  DateTime @default(now())

  @@unique([classroomId, studentId])
}

// ----------------------------------------------------------------------
// GAME ENGINE ARCHITECTURE
// ----------------------------------------------------------------------

// A template/collection of questions created by a teacher
model GameTemplate {
  id          String   @id @default(uuid())
  title       String
  category    String   @default("Genel")
  teacherId   String
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   GameQuestion[]
}

// A specific question / game activity inside a template
model GameQuestion {
  id             String       @id @default(uuid())
  gameTemplateId String
  gameTemplate   GameTemplate @relation(fields: [gameTemplateId], references: [id], onDelete: Cascade)
  
  // "QUIZ" (4 Options), "HANGMAN", "FILL_BLANK", "TRUE_FALSE"
  type           String       
  
  // The actual question text, or the prompt
  prompt         String
  
  // JSON stringified data
  // For QUIZ: { options: ["A", "B"], correctIndex: 0 }
  // For HANGMAN: { word: "ANADOLU", hint: "Bir yarımada" }
  // For FILL_BLANK: { text: "Osmanlı devleti ___ yılında kurulmuştur", answers: ["1299"] }
  // For TRUE_FALSE: { isTrue: true }
  payload        String
  
  timeLimit      Int          @default(30) // Seconds
  orderIndex     Int          @default(0)
  createdAt      DateTime     @default(now())
}

